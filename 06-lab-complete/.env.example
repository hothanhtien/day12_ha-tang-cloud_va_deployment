# ============================================================
# Copy file này thành .env.local rồi điền giá trị thật
#   cp .env.example .env.local
# ❌ KHÔNG commit .env.local lên Git
# ============================================================

# ── Server ───────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
ENVIRONMENT=production
DEBUG=false

# ── App ──────────────────────────────────────────────────────
APP_NAME=AI Agent
APP_VERSION=1.0.0

# ── LLM (OpenAI) ─────────────────────────────────────────────
# Lấy tại: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...
LLM_MODEL=gpt-4o-mini

# ── Security ─────────────────────────────────────────────────
# AGENT_API_KEY: bạn tự đặt, dùng để nhập vào UI khi chat
# Ví dụ: openssl rand -hex 16
AGENT_API_KEY=thay-bang-key-ban-tu-dat

# JWT_SECRET: chuỗi random dài, không cần nhớ
# Ví dụ: openssl rand -hex 32
JWT_SECRET=thay-bang-chuoi-random-dai

# ── Rate & Budget ─────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=20
DAILY_BUDGET_USD=5.0

# ── Storage (giữ nguyên khi dùng docker compose) ─────────────
REDIS_URL=redis://redis:6379/0

# ── CORS ─────────────────────────────────────────────────────
# Cho phép UI ở domain nào gọi API
# Dùng * để cho phép tất cả, hoặc điền domain cụ thể
ALLOWED_ORIGINS=https://tien-lab.khoav4.com
